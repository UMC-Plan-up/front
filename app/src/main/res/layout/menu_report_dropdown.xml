<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:maxHeight="240dp">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dashed_border_top_empty">
        <TextView
            android:id="@+id/presenter_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="욕설/비방/혐오 표현 사용"
            android:textColor="@color/black_400" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="@drawable/dash_line"/>
        <TextView
            android:id="@+id/adult_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="음란물/선정적 내용"
            android:textColor="@color/black_400" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="@drawable/dash_line"/>
        <TextView
            android:id="@+id/spam_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="스팸/광고"
            android:textColor="@color/black_400" />


    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="@drawable/dash_line"/>
        <TextView
            android:id="@+id/hate_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="불쾌하거나 부적절한 내용"
            android:textColor="@color/black_400" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="@drawable/dash_line"/>
        <TextView
            android:id="@+id/fake_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="거짓 정보 및 사칭"
            android:textColor="@color/black_400" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="@drawable/dash_line"/>

        <TextView
            android:id="@+id/etc_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:text="기타"
            android:textColor="@color/black_400" />
</LinearLayout>
</ScrollView>